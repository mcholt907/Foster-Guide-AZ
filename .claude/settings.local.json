{
  "permissions": {
    "allow": [
      "Bash(claude mcp:*)",
      "Bash(python -m json.tool)",
      "Bash(npx tsc --noEmit:*)",
      "Bash(npm test:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/ts-check.js" },
          { "type": "command", "command": "node .claude/hooks/vitest-check.js" }
        ]
      }
    ]
  }
}
